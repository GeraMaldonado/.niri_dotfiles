# Mako notification daemon - Purple Dark theme

# Layout
max-visible=5
layer=overlay
anchor=top-right
margin=8
width=260
height=90

# Styling (Purple theme)
background-color=#0a0e27
text-color=#e8e8f0
border-color=#a78bfa
border-size=1
border-radius=0
padding=10

# Font
font=Iosevka 10

# Icons
max-icon-size=48
icon-path=/usr/share/icons/Adwaita

# Timing
default-timeout=8000
ignore-timeout=1

# History (keep notifications for waybar script)
max-history=50

# Grouping
group-by=app-name

# Urgency levels
[urgency=low]
background-color=#0a0e27
text-color=#2d3561
border-color=#60a5fa
default-timeout=4000

[urgency=normal]
background-color=#0a0e27
text-color=#e8e8f0
border-color=#a78bfa
default-timeout=8000

[urgency=critical]
background-color=#0a0e27
text-color=#f472b6
border-color=#d946ef
default-timeout=0
text-color=#e7e3ff
border-color=#f38ba8
default-timeout=0

[mode=do-not-disturb]
invisible=1

[mode=do-not-disturb app-name=notify-send]
invisible=0
